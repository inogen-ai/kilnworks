# Kilnworks environment variables. Copy to .env and fill in what you need.
#
# Local dev (`uv run kilnworks ...`) reads .env directly (see src/kilnworks/settings.py).
# `docker compose up` only picks up variables that compose.yaml's `&kilnworks-env`
# anchor references from your shell/.env at compose-invocation time — defaults below
# match that anchor where it sets one; a few local-dev-only settings (marked below)
# aren't wired through compose and only affect `uv run` usage.
#
# Defaults shown are what Kilnworks uses when a variable is unset.

# ---- Core / database ----

# Postgres connection string. Local-dev-only: docker compose hardcodes this to the
# `db` service internally and does not read this variable.
KILNWORKS_DATABASE_URL=postgresql://kilnworks:kilnworks@localhost:5432/kilnworks

# SECRET. JWT signing key, must be >= 32 chars. Generate with: openssl rand -hex 32
# compose.yaml falls back to a development-only placeholder if this is unset — do not
# use that placeholder for anything real.
KILNWORKS_SECRET_KEY=

# Use canned deterministic responses instead of calling real providers (no API keys
# needed). Handy for offline dev and what CI's eval gate runs against.
KILNWORKS_FAKE_PROVIDERS=false

# Directory for uploaded files.
KILNWORKS_DATA_DIR=./data  # Local-dev-only: compose hardcodes /data in the anchor

# Max upload size in bytes (25 MiB). Local-dev-only: not wired through compose.
KILNWORKS_MAX_UPLOAD_BYTES=26214400

# API database connection pool size. Local-dev-only: not wired through compose.
KILNWORKS_DB_POOL_SIZE=10

# ---- Providers (chat & embeddings) ----

# Chat backend: openai, anthropic, or ollama.
KILNWORKS_CHAT_PROVIDER=openai

# Embedding backend: openai or ollama.
KILNWORKS_EMBEDDING_PROVIDER=openai

# SECRET. Required for the default OpenAI chat/embedding providers.
KILNWORKS_OPENAI_API_KEY=

# OpenAI chat model.
KILNWORKS_CHAT_MODEL=gpt-4o-mini

# OpenAI embedding model.
KILNWORKS_EMBEDDING_MODEL=text-embedding-3-small

# Vector column width; must match the embedding model. Capped at 2000 (pgvector HNSW
# limit). Changing this requires re-running `kilnworks init-db` and re-ingesting.
KILNWORKS_EMBEDDING_DIMENSIONS=1536

# SECRET. Required when KILNWORKS_CHAT_PROVIDER=anthropic.
KILNWORKS_ANTHROPIC_API_KEY=

# Anthropic chat model.
KILNWORKS_ANTHROPIC_MODEL=claude-opus-4-8

# Anthropic max output tokens per answer.
KILNWORKS_ANTHROPIC_MAX_TOKENS=2048

# Ollama server URL. docker compose overrides the default to
# http://host.docker.internal:11434 so containers can reach an Ollama server on the host.
KILNWORKS_OLLAMA_BASE_URL=http://localhost:11434

# Ollama chat model.
KILNWORKS_OLLAMA_CHAT_MODEL=llama3.2

# Ollama embedding model.
KILNWORKS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Ollama context window; small defaults truncate RAG prompts.
KILNWORKS_OLLAMA_NUM_CTX=8192

# Ollama request timeout in seconds (generation can be slow on CPU).
KILNWORKS_OLLAMA_TIMEOUT_SECONDS=300.0

# ---- Auth / OIDC (SSO) ----

# Bearer token lifetime in minutes. Local-dev-only: not wired through compose.
KILNWORKS_TOKEN_TTL_MINUTES=60

# IdP issuer URL; must be https:// except for localhost. Set together with
# KILNWORKS_OIDC_CLIENT_ID to enable SSO; setting only one fails startup.
KILNWORKS_OIDC_ISSUER=

# OAuth client ID registered with the IdP.
KILNWORKS_OIDC_CLIENT_ID=

# SECRET. Client secret; omit for public clients (PKCE is always used regardless).
KILNWORKS_OIDC_CLIENT_SECRET=

# ID-token claim mapped to ACL principals.
KILNWORKS_OIDC_GROUPS_CLAIM=groups

# Scopes requested at the authorization endpoint.
KILNWORKS_OIDC_SCOPES=openid email profile

# ---- Worker / jobs ----

# Worker idle poll interval in seconds. Local-dev-only: not wired through compose.
KILNWORKS_WORKER_POLL_SECONDS=1.0

# Max wall-clock time per job, in seconds.
KILNWORKS_JOB_TIMEOUT_SECONDS=300

# Lease duration for stalled-job reclaim, in seconds; must exceed
# KILNWORKS_JOB_TIMEOUT_SECONDS (enforced at worker startup).
KILNWORKS_JOB_LEASE_SECONDS=420

# ---- API / UI ----

# `kilnworks serve` bind host. compose sets this to 0.0.0.0 for container networking.
KILNWORKS_API_HOST=127.0.0.1

# `kilnworks serve` bind port. Local-dev-only: not wired through compose (compose maps
# the container's default port 8000 to the host instead).
KILNWORKS_API_PORT=8000

# Built UI directory served at /. Local-dev-only: not wired through compose (the
# Docker image bakes web/dist in at its default location).
KILNWORKS_WEB_DIST_DIR=
